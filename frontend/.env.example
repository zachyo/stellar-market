NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_PLATFORM_MIN_BUDGET_XLM=1
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# The canonical public URL of the site, used for OG tags and sitemap
NEXT_PUBLIC_SITE_URL=https://stellarmarket.io

# Web Push Notifications (VAPID public key only)
# Must match the VAPID_PUBLIC_KEY in backend .env
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
